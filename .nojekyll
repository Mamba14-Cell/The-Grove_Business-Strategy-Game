      <circle cx="90" cy="58" r="11" fill="#C62828" opacity="0.8"/>
      <circle cx="40" cy="68" r="10" fill="#D62828" opacity="0.75"/>
      <circle cx="112" cy="66" r="10" fill="#B71C1C" opacity="0.75"/>
      <circle cx="70" cy="50" r="9" fill="#EF5350" opacity="0.7"/>
      <circle cx="96" cy="76" r="8" fill="#E53935" opacity="0.65"/>
      <circle cx="56" cy="96" r="7" fill="#C62828" opacity="0.6"/>
    </svg>`,
    `<svg width="${w}" height="${h}" viewBox="0 0 160 200">
      <rect x="70" y="96" width="18" height="99" rx="9" fill="#5C3D2E"/>
      <line x1="79" y1="128" x2="24" y2="100" stroke="#5C3D2E" stroke-width="12" stroke-linecap="round"/>
      <line x1="79" y1="116" x2="134" y2="90" stroke="#5C3D2E" stroke-width="12" stroke-linecap="round"/>
      <line x1="24" y1="100" x2="6" y2="126" stroke="#5C3D2E" stroke-width="7" stroke-linecap="round"/>
      <line x1="134" y1="90" x2="154" y2="114" stroke="#5C3D2E" stroke-width="7" stroke-linecap="round"/>
      <line x1="79" y1="152" x2="44" y2="178" stroke="#5C3D2E" stroke-width="6" stroke-linecap="round"/>
      <line x1="79" y1="152" x2="114" y2="176" stroke="#5C3D2E" stroke-width="6" stroke-linecap="round"/>
      <circle cx="79" cy="52" r="58" fill="#3A7A0A"/>
      <circle cx="79" cy="52" r="58" fill="none" stroke="#2A6A00" stroke-width="2" opacity="0.4"/>
      <circle cx="50" cy="68" r="14" fill="#A00000"/>
      <circle cx="76" cy="80" r="14" fill="#B71C1C" opacity="0.95"/>
      <circle cx="102" cy="68" r="13" fill="#A00000" opacity="0.9"/>
      <circle cx="58" cy="50" r="13" fill="#C62828" opacity="0.85"/>
      <circle cx="92" cy="40" r="13" fill="#B71C1C" opacity="0.85"/>
      <circle cx="32" cy="60" r="12" fill="#C62828" opacity="0.8"/>
      <circle cx="120" cy="56" r="12" fill="#A00000" opacity="0.8"/>
      <circle cx="68" cy="32" r="11" fill="#D62828" opacity="0.75"/>
      <circle cx="96" cy="62" r="11" fill="#E53935" opacity="0.7"/>
      <circle cx="48" cy="80" r="10" fill="#B71C1C" opacity="0.65"/>
      <circle cx="108" cy="80" r="10" fill="#C62828" opacity="0.65"/>
      <circle cx="80" cy="16" r="9" fill="#EF5350" opacity="0.55"/>
    </svg>`
  ];
  return configs[Math.min(stage,4)].replace('width="160"',`width="${w}"`).replace('height="200"',`height="${h}"`);
}

/* ==================== GAME STATE ==================== */
let gs={
  screen:'intro',
  treeType:null,
  stageIdx:0,
  scenarioIdx:0,
  metrics:{sun:5,rain:5,soil:5},
  prevMetrics:{sun:5,rain:5,soil:5},
  xp:0,
  totalXP:0,
  phase:'choosing',
  lastChoice:null,
  forest:[],
  XP_PER_STAGE:100
};

function clamp(v){return Math.max(0,Math.min(10,Math.round(v)))}
function applyEffect(e){
  gs.prevMetrics={...gs.metrics};
  gs.metrics.sun=clamp(gs.metrics.sun+e.sun);
  gs.metrics.rain=clamp(gs.metrics.rain+e.rain);
  gs.metrics.soil=clamp(gs.metrics.soil+e.soil);
}

function getRank(){
  const avg=(gs.metrics.sun+gs.metrics.rain+gs.metrics.soil)/3;
  const ranks=t('ranks');
  if(avg>=8) return ranks[3];
  if(avg>=6) return ranks[2];
  if(avg>=4) return ranks[1];
  return ranks[0];
}

/* ==================== RENDER ==================== */
function render(){
  const el=document.getElementById('root');
  if(gs.screen==='intro') el.innerHTML=renderIntro();
  else if(gs.screen==='game') el.innerHTML=renderGame();
  else el.innerHTML=renderScore();
}

function renderIntro(){
  const trees=getTreeData();
  return `
  <p class="intro-text">${t('intro_text')}</p>
  <p style="font-size:12px;text-align:center;color:var(--bark-light);letter-spacing:0.06em;margin-bottom:10px;text-transform:uppercase;font-weight:500">${t('choose_tree')}</p>
  <div class="tree-grid">
    ${Object.entries(trees).map(([k,tr])=>`
      <div class="tree-card ${gs.treeType===k?'active':''}" onclick="selectTree('${k}')">
        <div class="tree-svg-preview">${treeSVG(k,gs.treeType===k?2:1,'small')}</div>
        <div class="tree-name">${tr.name}</div>
        <div class="tree-trait">${tr.trait}</div>
      </div>`).join('')}
  </div>
  ${gs.treeType?`<p class="tree-desc">${trees[gs.treeType].desc}</p>`:''}
  <div class="btn-row">
    <button class="btn btn-primary" onclick="startGame()" ${!gs.treeType?'disabled':''} style="width:100%">${t('plant_seed')}</button>
  </div>`;
}

function metricDelta(key){
  const d=gs.metrics[key]-gs.prevMetrics[key];
  if(d>0) return `<span style="color:#2D6A4F;font-size:11px;font-weight:500"> +${d}</span>`;
  if(d<0) return `<span style="color:#C62828;font-size:11px;font-weight:500"> ${d}</span>`;
  return '';
}

function renderStats(pulseKey){
  const icons={sun:'☀️',rain:'💧',soil:'🌍'};
  const labels={sun:t('resources'),rain:t('trust'),soil:t('strategy')};
  const fillClass={sun:'fill-sun',rain:'fill-rain',soil:'fill-soil'};
  return `<div class="stats-row">
    ${['sun','rain','soil'].map(k=>`
      <div class="stat-card ${pulseKey===k?'pulse':''}">
        <div class="stat-header"><span class="stat-icon">${icons[k]}</span><span class="stat-name">${labels[k]}</span></div>
        <div class="stat-val">${gs.metrics[k]}${pulseKey?metricDelta(k):''}</div>
        <div class="stat-bar"><div class="stat-fill ${fillClass[k]}" style="width:${gs.metrics[k]*10}%"></div></div>
      </div>`).join('')}
  </div>`;
}

function renderGame(){
  const sc=getScenarios()[gs.scenarioIdx];
  const stages=t('stages');
  const stageLabel=stages[gs.stageIdx]||stages[stages.length-1];
  const pct=Math.min(100,Math.round((gs.xp/gs.XP_PER_STAGE)*100));
  const level=gs.stageIdx+1;
  const treeData=getTreeData();

  let html=`
  <div class="stage-scene">
    <div class="scene-sky"></div>
    <div class="scene-clouds"><div class="cloud"></div><div class="cloud"></div><div class="cloud"></div></div>
    <div class="scene-tree">${treeSVG(gs.treeType,gs.stageIdx,'full')}</div>
    <div class="scene-ground"></div>
    <div class="stage-badge">${stageLabel}</div>
    <div class="level-badge">${t('level')} ${level}</div>
  </div>
  <div class="xp-row">
    <div class="xp-labels"><span>${t('stage_progress')}</span><span>${gs.xp}/${gs.XP_PER_STAGE} XP</span></div>
    <div class="xp-track"><div class="xp-fill" style="width:${pct}%"></div></div>
  </div>
  ${renderStats(gs.phase==='outcome'?'sun':null)}`;

  if(gs.phase==='choosing'){
    html+=`
    <div class="scenario-card">
      <div class="scenario-phase">${sc.phase} · ${stageLabel}</div>
      <div class="scenario-q">${sc.q}</div>
      <div class="scenario-body">${sc.body}</div>
    </div>
    <div class="choices">
      ${sc.choices.map((c,i)=>`
        <div class="choice" onclick="choose(${i})">
          <div class="choice-label">${c.label}</div>
          <div class="choice-sub">${c.sub}</div>
        </div>`).join('')}
    </div>
    ${buildTipPanel(gs.scenarioIdx)}`;
  } else {
    const c=gs.lastChoice;
    const deltas=[
      {k:'sun',v:c.effect.sun,icon:'☀️'},{k:'rain',v:c.effect.rain,icon:'💧'},{k:'soil',v:c.effect.soil,icon:'🌍'}
    ];
    html+=`<div class="outcome-wrap">
    <div class="outcome-banner outcome-${c.type}">
      <div class="outcome-title">${t('you_chose')} ${c.label}</div>
      ${c.outcome}
    </div>
    <div class="insight-card">
      <div class="insight-leaf">🌱</div>
      <div class="insight-label">${t('root_insight')}</div>
      <div class="insight-text">${c.insight}</div>
    </div>
    <div class="delta-row">
      ${deltas.map(d=>`<span class="delta ${d.v>0?'d-up':d.v<0?'d-down':'d-zero'}">${d.icon} ${d.v>0?'+':''}${d.v}</span>`).join('')}
      <span class="delta d-xp">+${c.xp} XP</span>
    </div>
    <div class="btn-row">
      <button class="btn btn-primary" onclick="nextStage()">${gs.scenarioIdx>=getScenarios().length-1?'View your results →':t('continue')}</button>
    </div>
    ${buildOutcomeTipPanel(gs.scenarioIdx)}
    </div>`;
  }

  if(gs.forest.length>0){
    const treeEmojis={oak:'🌳',bamboo:'🎋',fruit:'🍊'};
    const treeLabel=gs.forest.length===1?t('trees_label')[0]:t('trees_label')[1];
    html+=`<div class="forest-section">
      <div class="forest-title">${t('your_forest')} (${gs.forest.length} ${treeLabel})</div>
      <div class="forest-ground">
        ${gs.forest.map((tp,i)=>`<div class="forest-tree-item" style="animation-delay:${i*0.12}s">${treeSVG(tp,4,'small')}</div>`).join('')}
      </div>
    </div>`;
  }
  return html;
}

function renderScore(){
  const treeData=getTreeData();
  const treeEmojis={oak:'🌳',bamboo:'🎋',fruit:'🍊'};
  const rank=getRank();
  const avg=Math.round((gs.metrics.sun+gs.metrics.rain+gs.metrics.soil)/3*10);
  const scoreLabels=t('score_labels');
  const treeLabel=gs.forest.length===1?t('trees_label')[0]:t('trees_label')[1];

  return `<div class="score-screen">
  <div class="score-hero">
    <div class="score-tree-big">${treeSVG(gs.treeType,4,'full')}</div>
    <div class="score-rank">${rank}</div>
    <div class="score-xp">${gs.totalXP} ${t('total_xp')}</div>
  </div>
  <div class="medals-row">
    <div class="medal-card"><span class="medal-icon">☀️</span><div class="medal-val">${gs.metrics.sun}/10</div><div class="medal-label">${scoreLabels.resources}</div></div>
    <div class="medal-card"><span class="medal-icon">💧</span><div class="medal-val">${gs.metrics.rain}/10</div><div class="medal-label">${scoreLabels.trust}</div></div>
    <div class="medal-card"><span class="medal-icon">🌍</span><div class="medal-val">${gs.metrics.soil}/10</div><div class="medal-label">${scoreLabels.strategy}</div></div>
  </div>
  <div class="forest-section" style="margin-bottom:1.25rem">
    <div class="forest-title">${t('your_forest')} (${gs.forest.length} ${treeLabel})</div>
    <div class="forest-ground">
      ${gs.forest.map((tp,i)=>`<div class="forest-tree-item" style="animation-delay:${i*0.12}s">${treeSVG(tp,4,'small')}</div>`).join('')}
    </div>
  </div>
  ${buildScoreReflections()}
  <div class="btn-row" style="justify-content:center">
    <button class="btn btn-primary" onclick="plantAnother()">${t('play_again')}</button>
  </div></div>`;
}

/* ==================== ACTIONS ==================== */
function selectTree(type){gs.treeType=type;render();}

function startGame(){
  if(!gs.treeType) return;
  gs.screen='game';gs.stageIdx=0;gs.scenarioIdx=0;
  gs.metrics={sun:5,rain:5,soil:5};gs.prevMetrics={sun:5,rain:5,soil:5};
  gs.xp=0;gs.phase='choosing';gs.lastChoice=null;
  render();
}

function choose(i){
  const sc=getScenarios()[gs.scenarioIdx];
  const c=sc.choices[i];
  applyEffect(c.effect);
  gs.xp=Math.min(gs.xp+c.xp, gs.XP_PER_STAGE);
  gs.totalXP+=c.xp;
  gs.lastChoice=c;
  gs.phase='outcome';
  render();
  // pulse effect on stat cards
  setTimeout(()=>{
    document.querySelectorAll('.stat-card').forEach((el,idx)=>{
      const keys=['sun','rain','soil'];
      const key=keys[idx];
      const d=gs.metrics[key]-gs.prevMetrics[key];
      if(d!==0){el.classList.add('pulse');setTimeout(()=>el.classList.remove('pulse'),600);}
    });
  },100);
}

function nextStage(){
  gs.scenarioIdx++;
  if(gs.scenarioIdx>=getScenarios().length){
    gs.forest=[...gs.forest,gs.treeType]; // add once on completion
    gs.screen='score';
    render();
    return;
  }
  gs.stageIdx=Math.min(gs.scenarioIdx,4);
  gs.phase='choosing';
  gs.lastChoice=null;
  gs.xp=Math.min(gs.xp, gs.XP_PER_STAGE);
  render();
}

function plantAnother(){
  gs.screen='intro';gs.treeType=null;
  gs.stageIdx=0;gs.scenarioIdx=0;
  gs.metrics={sun:5,rain:5,soil:5};gs.prevMetrics={sun:5,rain:5,soil:5};
  gs.xp=0;gs.phase='choosing';gs.lastChoice=null;
  render();
}

