        <ellipse cx="80" cy="62" rx="20" ry="16" fill="#4CAF7D" opacity="0.6"/>
      </svg>`,
      // Stage 3: Mature
      `<svg width="${w}" height="${h}" viewBox="0 0 160 200">
        <rect x="72" y="115" width="16" height="80" rx="8" fill="#6B4226"/>
        <line x1="80" y1="148" x2="36" y2="126" stroke="#6B4226" stroke-width="8" stroke-linecap="round"/>
        <line x1="80" y1="138" x2="124" y2="118" stroke="#6B4226" stroke-width="8" stroke-linecap="round"/>
        <line x1="80" y1="168" x2="48" y2="188" stroke="#6B4226" stroke-width="5" stroke-linecap="round"/>
        <line x1="80" y1="168" x2="112" y2="186" stroke="#6B4226" stroke-width="5" stroke-linecap="round"/>
        <ellipse cx="80" cy="78" rx="55" ry="40" fill="#1A4731"/>
        <ellipse cx="36" cy="100" rx="32" ry="24" fill="#2D6A4F" opacity="0.9"/>
        <ellipse cx="124" cy="96" rx="32" ry="24" fill="#2D6A4F" opacity="0.9"/>
        <ellipse cx="80" cy="58" rx="38" ry="28" fill="#3D8B5E"/>
        <ellipse cx="54" cy="70" rx="24" ry="18" fill="#52B788" opacity="0.8"/>
        <ellipse cx="106" cy="68" rx="24" ry="18" fill="#52B788" opacity="0.8"/>
