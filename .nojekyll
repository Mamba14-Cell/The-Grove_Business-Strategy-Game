        <ellipse cx="80" cy="102" rx="20" ry="16" fill="#52B788" opacity="0.7"/>
      </svg>`,
      // Stage 2: Established
      `<svg width="${w}" height="${h}" viewBox="0 0 160 200">
        <rect x="74" y="130" width="12" height="65" rx="6" fill="#7B5230"/>
        <line x1="80" y1="158" x2="48" y2="140" stroke="#7B5230" stroke-width="6" stroke-linecap="round"/>
        <line x1="80" y1="150" x2="112" y2="134" stroke="#7B5230" stroke-width="6" stroke-linecap="round"/>
        <ellipse cx="80" cy="100" rx="42" ry="32" fill="#1E5C3A"/>
