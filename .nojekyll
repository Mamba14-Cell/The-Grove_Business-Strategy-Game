let lang = 'en';
function t(k){ return T[lang][k] || T['en'][k] || k; }
function setLang(l){
  lang=l;
  document.querySelectorAll('.lang-btn').forEach(b=>b.classList.toggle('active',b.textContent===l.toUpperCase()));
  document.getElementById('hdr-sub').textContent=t('subtitle');
  render();
}

/* ==================== SCENARIOS ==================== */
const SCENARIOS_EN = [
  {
    stage:0,phase:'Foundation',
    q:"Before you plant, you must prepare the ground. Your first critical resource decision:",
    body:"You have 50 units of capital. The market window is open, but so are several risks. How do you allocate your starting resources?",
    choices:[
      {label:"Invest 80% in product, 20% reserve",sub:"Build the best possible core before launch",effect:{sun:2,rain:0,soil:3},type:'great',
       outcome:"Solid roots. Your product quality attracts early believers who become vocal advocates. The reserve protects you when a supplier raises prices unexpectedly.",
       insight:"Resource concentration in early stages creates compounding quality advantages — the basis of Warren Buffett's 'economic moat' theory.",xp:35},
      {label:"Split evenly: product, marketing, ops",sub:"Balance all pillars from day one",effect:{sun:1,rain:2,soil:1},type:'ok',
       outcome:"Balanced start. Nothing exceptional, but nothing breaks. You establish presence across all dimensions — a solid if unremarkable foundation.",
       insight:"Even resource distribution is the default choice for most founders. It's safe — but rarely produces category leaders. Prioritisation is a strategic skill.",xp:22},
      {label:"Go all-in: 100% on fast market entry",sub:"Speed is the only moat that matters now",effect:{sun:3,rain:-1,soil:-1},type:'tough',
       outcome:"Fast entry, thin roots. You get to market quickly but product gaps show. Early customers churn faster than you acquire them. Trust must be rebuilt.",
       insight:"Speed advantages erode quickly without underlying quality. The lean startup methodology advocates speed — but with rapid learning loops, not recklessness.",xp:15}
    ]
  },
  {
    stage:1,phase:'Early Growth',
    q:"A competitor enters your market with a similar product at 30% lower price. Your response?",
    body:"Your sapling is growing steadily when an established player notices your traction and launches a competing product. They have more resources. You have agility.",
    choices:[
      {label:"Double down on your niche — be more specific",sub:"Serve your core customers better than anyone",effect:{sun:1,rain:3,soil:2},type:'great',
       outcome:"Brilliant positioning. You become the undisputed expert for a specific segment. The competitor's broad approach can't match your depth. NPS climbs to 72.",
       insight:"Porter's Focus Strategy: dominating a narrow market creates more durable advantages than competing broadly. Apple's premium niche strategy is the classic example.",xp:38},
      {label:"Match the price cut — protect market share",sub:"Don't let them steal your customers",effect:{sun:-2,rain:1,soil:0},type:'tough',
       outcome:"Short-term relief, long-term damage. You retain customers but gut your margins. With less to invest in product, the competitor gap widens slowly.",
       insight:"Price wars destroy value for everyone. Once started, they're hard to exit. Companies that compete on price alone rarely build lasting businesses.",xp:18},
      {label:"Accelerate roadmap — out-innovate them",sub:"Make their copy irrelevant before launch",effect:{sun:0,rain:1,soil:3},type:'great',
       outcome:"Bold move. You ship three major features before their launch date. Customers see you as the innovation leader; the competitor looks reactive on arrival.",
       insight:"Innovation velocity as competitive response is the foundation of the Blue Ocean Strategy — create new value instead of fighting over existing value.",xp:32}
    ]
  },
  {
    stage:2,phase:'Scaling',
    q:"You're growing 20% month-over-month. You must choose your scaling strategy.",
    body:"The tree is established. Now the question isn't survival — it's how fast and in which direction to grow. Three paths emerge simultaneously.",
    choices:[
      {label:"Hire aggressively — scale the team first",sub:"Growth requires people; build the org now",effect:{sun:-1,rain:2,soil:2},type:'ok',
       outcome:"Team growth brings capability but also coordination cost. You hire 12 in 3 months. Culture dilutes slightly. Revenue grows but so does complexity.",
       insight:"Brooks' Law: adding people to a project can slow it down. High-growth companies often find that culture and process must scale before headcount.",xp:25},
      {label:"Build systems and playbooks first",sub:"Make the machine before scaling the machine",effect:{sun:1,rain:1,soil:3},type:'great',
       outcome:"Counter-intuitive genius. You spend 6 weeks documenting everything. Then scaling is dramatically faster. Each hire ramps in 2 weeks instead of 8.",
       insight:"The E-Myth principle: work ON the business before working IN it. McDonald's scale is built on systems, not individual talent.",xp:40},
      {label:"Geographic expansion — new markets now",sub:"First mover advantage in new regions",effect:{sun:2,rain:-1,soil:1},type:'ok',
       outcome:"Mixed results. The new market has different needs you didn't anticipate. You capture some revenue but the core market suffers from divided attention.",
       insight:"Market expansion before product-market fit solidification is a common scaling mistake. Uber's aggressive global expansion created costly culture and legal problems.",xp:20}
    ]
  },
  {
    stage:3,phase:'Maturity',
    q:"You face a genuine innovator's dilemma. A new technology threatens to make your core product obsolete in 3–5 years.",
    body:"Your mature tree is profitable and beloved. Then a startup demos technology that could fundamentally change how customers get what they need from you.",
    choices:[
      {label:"Acquire the startup — own the disruption",sub:"Buy the threat, integrate it, lead the transition",effect:{sun:-2,rain:2,soil:3},type:'great',
       outcome:"Expensive but visionary. Integration is hard — you nearly lose the founding team. But 18 months later, you're the only incumbent that made the transition.",
       insight:"Acquire-to-transform is how Google, Facebook, and Apple have repeatedly sidestepped disruption. Instagram, YouTube, and Android were all acquisitions.",xp:42},
      {label:"Build internal innovation lab — match it in-house",sub:"You have the resources; build your own version",effect:{sun:-1,rain:0,soil:2},type:'ok',
       outcome:"Slower than acquisition but you retain full control. The lab produces a credible product after 18 months. You're behind, but not fatally so.",
       insight:"The Innovator's Dilemma (Clayton Christensen) shows most incumbents fail to self-disrupt because their best customers don't want the new thing — yet.",xp:28},
      {label:"Defend the core — disruption timelines always slip",sub:"Five years is long enough to respond later",effect:{sun:1,rain:0,soil:-2},type:'tough',
       outcome:"The disruption arrives in 3.5 years, not 5. You're caught defending a shrinking market. Revenue holds 2 years then drops sharply. You scramble.",
       insight:"Incumbent denial is the most documented pattern in business history: Kodak, Blockbuster, Nokia. The timelines always feel longer than they are.",xp:12}
    ]
  },
  {
    stage:4,phase:'Legacy',
    q:"Your empire is established. How do you build it to outlast you?",
    body:"The forest is full. Customers depend on you. Employees build careers here. The question shifts from how to grow to how to endure.",
    choices:[
      {label:"Cultivate the next generation of leaders",sub:"Institutional knowledge must transfer",effect:{sun:0,rain:3,soil:2},type:'great',
       outcome:"The greatest legacy move. You identify five internal leaders and spend two years developing them. The company runs smoothly through leadership transitions.",
       insight:"Jim Collins' 'Built to Last' found that enduring companies prioritise leader development over founder dependency. They build clocks, not tell time.",xp:45},
      {label:"Open source core technology — give back to the ecosystem",sub:"Generosity as long-term competitive strategy",effect:{sun:-1,rain:2,soil:3},type:'great',
       outcome:"Audacious. The ecosystem grows up around your open technology. You attract the best engineers globally. Competitors who copy it accelerate your standard.",
       insight:"Ecosystem thinking reframes competition: when you own the platform others build on, competitive dynamics invert. Android, Linux, and AWS are ecosystem-first bets.",xp:45},
      {label:"Optimise for maximum profitability — harvest mode",sub:"Return value to stakeholders now",effect:{sun:3,rain:-2,soil:-1},type:'ok',
       outcome:"Financially rational short-term. But talent senses the shift and starts leaving. In 3 years, the business is profitable but hollowing out from the inside.",
       insight:"Harvest strategies work for finite-life assets, not for organisations with people at their core. Over-extraction destroys the ecosystem that generated the value.",xp:18}
    ]
  }
];

const SCENARIOS_PT = [
