  },
  {
    stage:2,phase:'Scalabilità',
    q:"Stai crescendo del 20% mese su mese. Devi scegliere la tua strategia di scalabilità.",
    body:"L'albero è consolidato. Ora la questione non è la sopravvivenza — è quanto velocemente e in quale direzione crescere. Tre percorsi emergono simultaneamente.",
    choices:[
      {label:"Assumere aggressivamente — scalare il team prima",sub:"La crescita richiede persone; costruisci l'organizzazione ora",effect:{sun:-1,rain:2,soil:2},type:'ok',
       outcome:"La crescita del team porta capacità ma anche costi di coordinamento. Assumi 12 in 3 mesi. La cultura si diluisce leggermente. I ricavi crescono ma anche la complessità.",
       insight:"La Legge di Brooks: aggiungere persone a un progetto può rallentarlo. Le aziende ad alta crescita spesso scoprono che cultura e processi devono scalare prima del personale.",xp:25},
      {label:"Costruire sistemi e playbook prima",sub:"Crea la macchina prima di scalare la macchina",effect:{sun:1,rain:1,soil:3},type:'great',
       outcome:"Genio controintuitivo. Passi 6 settimane a documentare tutto. Poi la scalabilità è drasticamente più rapida. Ogni assunzione si integra in 2 settimane invece di 8.",
       insight:"Il principio E-Myth: lavora SUL business prima di lavorare NEL business. La scalabilità di McDonald's è costruita su sistemi, non su talento individuale.",xp:40},
      {label:"Espansione geografica — nuovi mercati ora",sub:"Vantaggio del primo entrante in nuove regioni",effect:{sun:2,rain:-1,soil:1},type:'ok',
       outcome:"Risultati misti. Il nuovo mercato ha esigenze diverse che non avevi anticipato. Catturi qualche ricavo ma il mercato principale soffre per l'attenzione divisa.",
       insight:"L'espansione del mercato prima del consolidamento del product-market fit è un errore comune di scalabilità. L'espansione globale aggressiva di Uber ha creato costosi problemi di cultura e legali.",xp:20}
    ]
  },
  {
    stage:3,phase:'Maturità',
    q:"Affronti un genuino dilemma dell'innovatore. Una nuova tecnologia minaccia di rendere obsoleto il tuo prodotto principale in 3–5 anni.",
    body:"Il tuo albero maturo è redditizio e amato. Poi una startup presenta una tecnologia che potrebbe cambiare fondamentalmente il modo in cui i clienti ottengono ciò di cui hanno bisogno da te.",
    choices:[
      {label:"Acquisire la startup — appropriarsi della disruption",sub:"Compra la minaccia, integrala, guida la transizione",effect:{sun:-2,rain:2,soil:3},type:'great',
       outcome:"Costoso ma visionario. L'integrazione è difficile. Ma 18 mesi dopo, sei l'unico incumbent che ha completato la transizione con successo.",
       insight:"Acquisire per trasformare è come Google, Facebook e Apple hanno ripetutamente evitato la disruption. Instagram, YouTube e Android erano tutte acquisizioni.",xp:42},
      {label:"Creare laboratorio di innovazione interno",sub:"Hai le risorse; costruisci la tua versione in-house",effect:{sun:-1,rain:0,soil:2},type:'ok',
       outcome:"Più lento dell'acquisizione ma mantieni pieno controllo. Il laboratorio produce un prodotto credibile dopo 18 mesi. Sei indietro, ma non in modo fatale.",
       insight:"Il Dilemma dell'Innovatore (Clayton Christensen) mostra che la maggior parte degli incumbent fallisce nell'auto-disruptarsi perché i loro migliori clienti non vogliono ancora la novità.",xp:28},
      {label:"Difendere il nucleo — le tempistiche di disruption slittano sempre",sub:"Cinque anni sono abbastanza per rispondere dopo",effect:{sun:1,rain:0,soil:-2},type:'tough',
       outcome:"La disruption arriva in 3,5 anni, non 5. Ti ritrovi a difendere un mercato in contrazione. I ricavi reggono 2 anni poi calano bruscamente.",
       insight:"Il diniego dell'incumbent è il pattern più documentato nella storia aziendale: Kodak, Blockbuster, Nokia. Le tempistiche sembrano sempre più lunghe di quanto siano.",xp:12}
    ]
  },
  {
    stage:4,phase:'Eredità',
    q:"Il tuo impero è consolidato. Come lo costruisci per sopravviverti?",
    body:"La foresta è piena. I clienti dipendono da te. I dipendenti costruiscono carriere qui. La domanda passa da come crescere a come perdurare.",
    choices:[
      {label:"Coltivare la prossima generazione di leader",sub:"Il know-how istituzionale deve trasferirsi",effect:{sun:0,rain:3,soil:2},type:'great',
       outcome:"La mossa di eredità più grande. Identifichi cinque leader interni e passi due anni a svilupparli. L'azienda funziona perfettamente attraverso le transizioni di leadership.",
       insight:"'Built to Last' di Jim Collins ha scoperto che le aziende durature privilegiano lo sviluppo dei leader rispetto alla dipendenza dal fondatore. Costruiscono orologi, non dicono l'ora.",xp:45},
      {label:"Open source della tecnologia core — restituire all'ecosistema",sub:"La generosità come strategia competitiva a lungo termine",effect:{sun:-1,rain:2,soil:3},type:'great',
       outcome:"Audace. L'ecosistema cresce attorno alla tua tecnologia aperta. Attrai i migliori ingegneri globalmente. I concorrenti che la copiano accelerano il tuo standard.",
       insight:"Il pensiero ecosistemico ridefinisce la concorrenza: quando possiedi la piattaforma su cui gli altri costruiscono, le dinamiche competitive si invertono. Android, Linux e AWS sono scommesse ecosistema-first.",xp:45},
      {label:"Ottimizzare per massima redditività — modalità raccolto",sub:"Restituire valore agli stakeholder ora",effect:{sun:3,rain:-2,soil:-1},type:'ok',
       outcome:"Finanziariamente razionale a breve termine. Ma i talenti percepiscono il cambiamento e iniziano ad andarsene. In 3 anni, il business è redditizio ma si sta svuotando dall'interno.",
       insight:"Le strategie di raccolta funzionano per asset a vita finita, non per organizzazioni con persone al loro nucleo. L'estrazione eccessiva distrugge l'ecosistema che ha generato il valore.",xp:18}
    ]
  }
];

function getScenarios(){
  if(lang==='pt') return SCENARIOS_PT;
  if(lang==='it') return SCENARIOS_IT;
  return SCENARIOS_EN;
}

/* ==================== TREES ==================== */
function getTreeData(){
  const names={
    en:{oak:'Oak',bamboo:'Bamboo',fruit:'Fruit Tree'},
    pt:{oak:'Carvalho',bamboo:'Bambu',fruit:'Árvore Frutífera'},
    it:{oak:'Quercia',bamboo:'Bambù',fruit:'Albero da Frutto'}
  };
  return {
    oak:{name:names[lang].oak,trait:t('oak_trait'),desc:t('oak_desc'),color:'#2D6A4F'},
    bamboo:{name:names[lang].bamboo,trait:t('bamboo_trait'),desc:t('bamboo_desc'),color:'#52B788'},
    fruit:{name:names[lang].fruit,trait:t('fruit_trait'),desc:t('fruit_desc'),color:'#E07A5F'}
  };
}

/* === SVG TREES — richly detailed === */
function treeSVG(type, stage, size='full'){
  const s = size==='full' ? 1 : 0.55;
  const w = Math.round(160*s), h = Math.round(200*s);

  if(type==='oak'){
    const configs=[
      // Stage 0: Seed/sprout
      `<svg width="${w}" height="${h}" viewBox="0 0 160 200">
        <line x1="80" y1="190" x2="80" y2="155" stroke="#8B6547" stroke-width="5" stroke-linecap="round"/>
        <ellipse cx="80" cy="145" rx="16" ry="12" fill="#4CAF7D" opacity="0.9"/>
        <ellipse cx="68" cy="152" rx="10" ry="7" fill="#66BB8A" opacity="0.8" transform="rotate(-20,68,152)"/>
        <ellipse cx="92" cy="152" rx="10" ry="7" fill="#66BB8A" opacity="0.8" transform="rotate(20,92,152)"/>
      </svg>`,
      // Stage 1: Sapling
      `<svg width="${w}" height="${h}" viewBox="0 0 160 200">
        <rect x="76" y="145" width="8" height="50" rx="4" fill="#8B6547"/>
        <line x1="80" y1="172" x2="58" y2="158" stroke="#8B6547" stroke-width="4" stroke-linecap="round"/>
        <line x1="80" y1="165" x2="102" y2="153" stroke="#8B6547" stroke-width="4" stroke-linecap="round"/>
