      </svg>`
    ];
    return configs[Math.min(stage,4)].replace('width="160"',`width="${w}"`).replace('height="200"',`height="${h}"`);
  }

  // fruit
  const configs=[
    `<svg width="${w}" height="${h}" viewBox="0 0 160 200">
      <rect x="78" y="162" width="6" height="34" rx="3" fill="#8B6547"/>
