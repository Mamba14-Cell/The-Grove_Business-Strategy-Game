const SCORE_REFLECTIONS = {
  en: {
    title: 'Reflection Questions — take these into the real world',
    questions: [
      'Looking at your three scores, which one surprised you most — and what decision caused it?',
      'Which choice felt hardest to make? What does that reveal about your natural instincts as a strategist?',
      'If you played again with a different tree, what would you do differently — and why?',
      'How do your in-game decisions mirror real choices you face or have faced in your work?',
      'Which Root Insight resonated most with you — and how could you apply it this week?'
    ]
  },
  pt: {
    title: 'Questões para Reflexão — leve-as para o mundo real',
    questions: [
      'Olhando para suas três pontuações, qual te surpreendeu mais — e qual decisão a causou?',
      'Qual escolha foi mais difícil de fazer? O que isso revela sobre seus instintos naturais como estrategista?',
      'Se você jogasse novamente com uma árvore diferente, o que faria de diferente — e por quê?',
      'Como suas decisões no jogo espelham escolhas reais que você enfrenta ou enfrentou no trabalho?',
      'Qual Insight Raiz ressoou mais com você — e como poderia aplicá-lo esta semana?'
    ]
  },
  it: {
    title: 'Domande di Riflessione — portale nel mondo reale',
    questions: [
      'Guardando i tuoi tre punteggi, quale ti ha sorpreso di più — e quale decisione l\'ha causato?',
      'Quale scelta è stata più difficile da fare? Cosa rivela sui tuoi istinti naturali come stratega?',
      'Se giocassi di nuovo con un albero diverso, cosa faresti diversamente — e perché?',
      'Come le tue decisioni nel gioco rispecchiano scelte reali che affronti o hai affrontato nel lavoro?',
      'Quale Intuizione Radice ti ha colpito di più — e come potresti applicarla questa settimana?'
    ]
  }
};

function getTips(){ return lang==='pt'?TIPS_PT:lang==='it'?TIPS_IT:TIPS_EN; }

function toggleTip(id){
  const body=document.getElementById('tip-body-'+id);
  const chev=document.getElementById('tip-chev-'+id);
  if(!body||!chev) return;
  const isOpen=body.classList.contains('open');
  body.classList.toggle('open',!isOpen);
  chev.classList.toggle('open',!isOpen);
}

function buildTipPanel(scenarioIdx){
  const tips=getTips();
  const tip=tips[Math.min(scenarioIdx,tips.length-1)];
  if(!tip) return '';
  const id='tip'+scenarioIdx;
  return `<div class="tip-panel">
    <button class="tip-toggle" onclick="toggleTip('${id}')">
      <span class="tip-icon">💡</span>
      <span class="tip-toggle-label">${tip.toggle.replace('💡 ','')}</span>
      <span class="tip-chevron" id="tip-chev-${id}">▼</span>
    </button>
    <div class="tip-body" id="tip-body-${id}">
      <div class="tip-inner">
        <div class="tip-section">
          <div class="tip-section-title">${tip.tradeoffs_title}</div>
          ${tip.tradeoffs.map((tr,i)=>`<div class="tip-item"><span class="tip-bullet">${i+1}</span><span>${tr}</span></div>`).join('')}
        </div>
        <div class="tip-divider"></div>
        <div class="tip-section">
          <div class="tip-section-title">${tip.framework_label}</div>
          <div class="tip-framework">${tip.framework}</div>
        </div>
        <div class="tip-divider"></div>
        <div class="tip-section">
          <div class="tip-section-title">${tip.reflect_title}</div>
          ${tip.reflects.map(r=>`<div class="tip-item"><span class="tip-bullet">?</span><span>${r}</span></div>`).join('')}
        </div>
      </div>
    </div>
  </div>`;
}

function buildOutcomeTipPanel(scenarioIdx){
  const tips=getTips();
  const tip=tips[Math.min(scenarioIdx,tips.length-1)];
  if(!tip) return '';
  const id='otip'+scenarioIdx;
  const label=lang==='pt'?'Aprofundar o insight':lang==='it'?'Approfondisci l\'insight':'Deepen this insight';
  return `<div class="tip-panel" style="margin-top:0.75rem">
    <button class="tip-toggle" onclick="toggleTip('${id}')">
      <span class="tip-icon">📚</span>
      <span class="tip-toggle-label">${label}</span>
      <span class="tip-chevron" id="tip-chev-${id}">▼</span>
    </button>
    <div class="tip-body" id="tip-body-${id}">
      <div class="tip-inner">
        <div class="tip-section">
          <div class="tip-section-title">${tip.framework_label}</div>
          <div class="tip-framework">${tip.framework}</div>
        </div>
        <div class="tip-divider"></div>
        <div class="tip-section">
          <div class="tip-section-title">${tip.reflect_title}</div>
          ${tip.reflects.map(r=>`<div class="tip-item"><span class="tip-bullet">?</span><span>${r}</span></div>`).join('')}
        </div>
      </div>
    </div>
  </div>`;
}

function buildScoreReflections(){
  const ref=SCORE_REFLECTIONS[lang]||SCORE_REFLECTIONS['en'];
  return `<div class="reflection-card">
    <div class="reflection-title">${ref.title}</div>
    ${ref.questions.map(q=>`<div class="reflection-q">${q}</div>`).join('')}
  </div>`;
}

/* ==================== PARTICLES ==================== */
function spawnParticles(){
  const colors=['#52B788','#A8DABC','#C8E6C9','#F4A261','#FDE8C8'];
  for(let i=0;i<18;i++){
    const p=document.createElement('div');
    p.className='particle';
    const size=Math.random()*5+2;
    p.style.cssText=`
      width:${size}px;height:${size}px;
      background:${colors[Math.floor(Math.random()*colors.length)]};
      left:${Math.random()*100}vw;
      animation-duration:${Math.random()*20+15}s;
      animation-delay:${Math.random()*20}s;
    `;
    document.body.appendChild(p);
  }
}

spawnParticles();
render();
</script>
</body>
</html>
