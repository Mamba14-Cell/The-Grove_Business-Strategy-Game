const SCENARIOS_IT = [
  {
    stage:0,phase:'Fondazione',
    q:"Prima di piantare, devi preparare il terreno. La tua prima decisione critica sulle risorse:",
    body:"Hai 50 unità di capitale. La finestra di mercato è aperta, ma anche i rischi. Come allochi le risorse iniziali?",
    choices:[
      {label:"Investire l'80% nel prodotto, 20% di riserva",sub:"Costruisci il miglior nucleo possibile prima del lancio",effect:{sun:2,rain:0,soil:3},type:'great',
       outcome:"Radici solide. La qualità del tuo prodotto attrae i primi credenti che diventano sostenitori vocali. La riserva ti protegge quando un fornitore aumenta i prezzi inaspettatamente.",
